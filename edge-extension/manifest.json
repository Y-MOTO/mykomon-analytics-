{
  "manifest_version": 3,
  "name": "MyKomon 日報入力補助",
  "version": "1.0.0",
  "description": "MyKomonの日報入力をカード型UIで補助し、構造化タグを自動挿入します",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.mykomon.com/*",
    "https://*.mykomon.jp/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.mykomon.com/*", "https://*.mykomon.jp/*"],
      "js": ["content.js"],
      "world": "MAIN"
    }
  ]
}
